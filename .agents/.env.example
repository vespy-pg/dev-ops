# Agent Environment Configuration Example
# Copy this file to .env and customize locally.
# .env is git-ignored and must not be committed.

# SSH / server diagnostics
DINPANEL_HOST=91.98.116.49
DINPANEL_CODEX_USER=codex
DINPANEL_ADMIN_USER=pawel
DINPANEL_SSH_PORT=22
DINPANEL_CODEX_KEY=/var/www/workspace/vespy-dev-ops/codex-ssh

# Deployment targets
DINPANEL_PROD_APP_NAME=dinpanel
DINPANEL_PROD_BASE_DIR=/var/www/dinpanel
DINPANEL_TEST_APP_NAME=dinpanel-test
DINPANEL_TEST_BASE_DIR=/var/www/dinpanel-test

# Optional read-only database exploration
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=
